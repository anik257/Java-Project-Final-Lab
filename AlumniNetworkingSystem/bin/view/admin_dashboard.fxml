<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="800.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AdminDashboardController">
   <left>
      <VBox spacing="10.0" style="-fx-background-color: #1e293b; -fx-pref-width: 220px;">
         <padding>
            <Insets bottom="20.0" left="15.0" right="15.0" top="30.0" />
         </padding>
         <children>
            <Label style="-fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-font-size: 18px;" text="Admin Console" />
            <Label styleClass="subtitle-label" text="Manage Alumni Link" />
            <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-padding: 30px 0 0 0;">
               <children>
                  <Button fx:id="usersBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showUsersTab" styleClass="btn-primary" style="-fx-background-color: transparent; -fx-text-fill: #e2e8f0; -fx-alignment: center-left;" text="👥 Users List" />
                  <Button fx:id="createEventBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showCreateEventTab" styleClass="btn-primary" style="-fx-background-color: transparent; -fx-text-fill: #e2e8f0; -fx-alignment: center-left;" text="📅 Create Event" />
                  <Button fx:id="attendeesBtn" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showAttendeesTab" styleClass="btn-primary" style="-fx-background-color: transparent; -fx-text-fill: #e2e8f0; -fx-alignment: center-left;" text="🎟️ Event Attendees" />
               </children>
            </VBox>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="btn-primary" style="-fx-background-color: #ef4444;" text="Logout" />
         </children>
      </VBox>
   </left>
   <center>
      <StackPane styleClass="login-bg">
         <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <children>
            <!-- Users Tab -->
            <VBox fx:id="usersTab" spacing="15.0" visible="true" styleClass="card" style="-fx-padding: 20px;">
               <children>
                  <Label styleClass="title-label" text="Registered Users" />
                  <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="userIdCol" prefWidth="60.0" text="ID" />
                      <TableColumn fx:id="userNameCol" prefWidth="150.0" text="Name" />
                      <TableColumn fx:id="userEmailCol" prefWidth="200.0" text="Email" />
                      <TableColumn fx:id="userRoleCol" prefWidth="100.0" text="Role" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            <!-- Create Event Tab -->
            <VBox fx:id="createEventTab" spacing="15.0" visible="false" styleClass="card" style="-fx-padding: 20px;">
               <children>
                  <Label styleClass="title-label" text="Create New Networking Event" />
                  <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-max-width: 500px;">
                     <children>
                        <Label styleClass="normal-label" text="Event Title" />
                        <TextField fx:id="eventTitleField" promptText="FAANG Career Panel" />
                        <Label styleClass="normal-label" text="Description" />
                        <TextArea fx:id="eventDescArea" prefHeight="100.0" promptText="Enter event description..." wrapText="true" />
                        <Label styleClass="normal-label" text="Date &amp; Time (yyyy-MM-dd HH:mm)" />
                        <TextField fx:id="eventDateField" promptText="2026-06-25 14:00" />
                        <Label styleClass="normal-label" text="Location" />
                        <TextField fx:id="eventLocField" promptText="Zoom or Auditorium" />
                        <Label fx:id="eventStatusLabel" styleClass="success-label" visible="false" />
                        <Button mnemonicParsing="false" onAction="#handleCreateEvent" styleClass="btn-primary" text="Publish Event" />
                     </children>
                  </VBox>
               </children>
            </VBox>
            <!-- Event Attendees Tab -->
            <VBox fx:id="attendeesTab" spacing="15.0" visible="false" styleClass="card" style="-fx-padding: 20px;">
               <children>
                  <Label styleClass="title-label" text="Event Attendee List" />
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label styleClass="normal-label" text="Select Event:" />
                        <ComboBox fx:id="eventComboBox" onAction="#handleEventSelection" prefWidth="300.0" promptText="Choose an event" />
                     </children>
                  </HBox>
                  <TableView fx:id="attendeesTable" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="attendeeIdCol" prefWidth="60.0" text="ID" />
                      <TableColumn fx:id="attendeeNameCol" prefWidth="180.0" text="Name" />
                      <TableColumn fx:id="attendeeEmailCol" prefWidth="250.0" text="Email" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </StackPane>
   </center>
</BorderPane>
